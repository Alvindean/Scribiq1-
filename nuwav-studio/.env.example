# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com
APP_URL=https://your-domain.com
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://your-domain.com
AUTH_SECRET=your-secret-here

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@your-domain.com

# ── Database (Neon) ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# ── AI / OpenRouter + Claude ──────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
# Legacy / direct Anthropic key (optional if using OpenRouter)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── ElevenLabs TTS ────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# Note: the codebase references CLOUDFLARE_R2_* names in src/lib/media/r2.ts
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=https://pub-....r2.dev
# Aliases used in env-check / admin panel
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://pub-....r2.dev

# ── Upstash Redis (rate limiting) ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://....upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=NuWav Studio <onboarding@nuwavstudio.com>
EMAIL_FROM=noreply@nuwav.studio

# ── Spotify (optional — music analysis) ──────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Pixabay (optional — image/music search) ───────────────────────────────────
PIXABAY_API_KEY=

# ── Freesound (optional — music search) ──────────────────────────────────────
FREESOUND_API_KEY=

# ── iTunes ────────────────────────────────────────────────────────────────────
# Uses the public iTunes Search API — no key required
